# Containerless local development (Story 20.3).
#
# Copy to .env for local dev on macOS or Windows — no Postgres, Redis, MinIO, or Docker.
# Leave DATABASE_URL, AWS_*, and REDIS_URL UNSET so the base defaults apply: SQLite at
# backend/db.sqlite3 and FileSystemStorage at backend/media/. .env is gitignored; never
# commit secrets. For the container/prod stack, use .env.example instead.

# --- Django ---
SECRET_KEY=changeme-generate-a-real-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
DJANGO_SETTINGS_MODULE=config.settings.local

# --- Database ---
# DATABASE_URL intentionally UNSET -> SQLite at backend/db.sqlite3 (base default).

# --- Object storage ---
# AWS_* intentionally UNSET -> FileSystemStorage at backend/media/ (base default).

# --- Containerless Celery transport (Story 20.4) ---
# The container-free broker + result backend land in Story 20.4; leave REDIS_URL UNSET.
# Placeholders for the filesystem-transport vars Story 20.4 introduces (uncomment then):
# CELERY_BROKER_URL=filesystem://
# CELERY_BROKER_FILESYSTEM_DIR=./.celery/broker
# django-celery-results stores task results in the Django DB (SQLite) — no extra endpoint.

# --- Pipeline ---
SBOM_MAX_CONCURRENT_JOBS_PER_ORG=5
CELERY_TASK_SOFT_TIME_LIMIT=1800
CELERY_TASK_TIME_LIMIT=2100

# --- Initial superuser (global admin) — DEV CONVENIENCE ONLY; never commit real credentials.
# When both are set, `manage.py` seeding creates this global-admin superuser (Story 2.13).
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=changeme-admin-password
